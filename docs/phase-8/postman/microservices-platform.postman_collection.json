{
  "info": {
    "name": "Microservices Platform APIs",
    "_postman_id": "2f3b54a8-8f35-4c90-a920-2c71de67f8a4",
    "description": "Phase 8 API collection for gateway versioned routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"items\": [\n    {\n      \"productCode\": \"SKU-1001\",\n      \"quantity\": 2,\n      \"unitPrice\": 19.99\n    }\n  ]\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/orders"
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/orders/{{orderId}}"
          }
        },
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/orders/user/{{userId}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/orders/{{orderId}}/cancel"
          }
        },
        {
          "name": "Track Order Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/orders/status/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}},\n  \"userId\": {{userId}},\n  \"amount\": 39.98,\n  \"idempotencyKey\": \"manual-test-{{orderId}}\"\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/payments/process"
          }
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/payments/{{paymentId}}"
          }
        },
        {
          "name": "Get Payments By Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/payments/order/{{orderId}}"
          }
        },
        {
          "name": "Refund Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 39.98,\n  \"reason\": \"Customer requested cancellation\"\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/payments/{{paymentId}}/refund"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get User Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/notifications/user/{{userId}}"
          }
        },
        {
          "name": "Mark Notification As Read",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/notifications/{{notificationId}}/read"
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": "{{gatewayUrl}}/api/v1/notifications/{{notificationId}}"
          }
        },
        {
          "name": "Update Preferences",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"emailEnabled\": true,\n  \"smsEnabled\": false,\n  \"pushEnabled\": true,\n  \"inAppEnabled\": true\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/notifications/preferences"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "gatewayUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "bearerToken",
      "value": ""
    },
    {
      "key": "orderId",
      "value": "1"
    },
    {
      "key": "paymentId",
      "value": "1"
    },
    {
      "key": "notificationId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "1001"
    }
  ]
}
